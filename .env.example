# =============================================================================
# Code Training Lab — Docker Compose environment
# =============================================================================
#
# Two ways to run — pick one workflow:
#
# A) Local dev (infra only in Docker, API + FE on host):
#    docker compose -f docker-compose.local.yml up -d
#    ./scripts/build-runner-images.sh
#    ./gradlew :be:bootRun  &&  cd fe && npm run dev
#
# B) Full stack in Docker (no host JDK/Node):
#    docker compose up --build -d  →  http://localhost:3000
#
# GHCR images: docker-compose.prod.yml — see README.md.
# =============================================================================

# --- Docker socket (Linux: group id of /var/run/docker.sock) ---
# macOS Docker Desktop often works with 0; Linux: $(stat -c '%g' /var/run/docker.sock)
DOCKER_GID=0

# --- Host ports (published to your machine) ---
API_PORT=8080
FE_PORT=3000
PG_PORT=5432
RMQ_PORT=5672
RMQ_MGMT_PORT=15672

# --- PostgreSQL 17 ---
PG_USER=postgres
PG_PASSWORD=change-me-postgres
PG_DB=code_training_lab

# --- RabbitMQ ---
RMQ_USER=guest
RMQ_PASSWORD=change-me-rabbitmq

# --- Host bootRun only (./gradlew :be:bootRun + Docker postgres/rabbitmq on localhost) ---
# SPRING_PROFILES_ACTIVE=local
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/code_training_lab
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=change-me-postgres
# SPRING_RABBITMQ_HOST=localhost
# SPRING_RABBITMQ_PASSWORD=change-me-rabbitmq

# --- API security & features (injected into the api container) ---
SPRING_PROFILES_ACTIVE=production
JWT_SECRET=change-me-use-at-least-32-random-characters
REGISTRATION_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
CTL_DOCKER_ENABLED=true

# --- Runner images (docker-compose.runners.yml — `make runners`) ---
# Shared Maven cache speeds up repeated Run tests (host bootRun + Docker):
RUNNER_MAVEN_CACHE_VOLUME=ctl-runner-m2-cache
CTL_API_IMAGE=code-challenge-ide-be:local
CTL_FE_IMAGE=code-challenge-ide-fe:local
RUNNER_JAVA_17_IMAGE=code-challenge-ide-runner-java-17:local
RUNNER_JAVA_21_IMAGE=code-challenge-ide-runner-java-21:local
RUNNER_JAVA_25_IMAGE=code-challenge-ide-runner-java-25:local
RUNNER_JAVA_26_IMAGE=code-challenge-ide-runner-java-26:local
RUNNER_PYTHON_312_IMAGE=code-challenge-ide-runner-python-312:local
LSP_JAVA_IMAGE=code-challenge-ide-lsp-java:local
CTL_LSP_ENABLED=true

# --- GHCR (docker-compose.prod.yml only) ---
# CTL_IMAGE_REGISTRY=ghcr.io
# CTL_IMAGE_OWNER=your-github-username
# CTL_IMAGE_TAG=latest

# --- AI coaching (optional — operator pays provider usage) ---
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder
