# =============================================================================
# Code Training Lab — Docker Compose environment
# =============================================================================
#
# Two ways to run — pick one workflow:
#
# A) Local dev (infra only in Docker, API + FE on host):
#    make infra && make runners
#    ./gradlew :be:bootRun  &&  cd fe && npm run dev
#
# B) Full stack in Docker (no host JDK/Node):
#    docker compose up --build -d  →  http://localhost:3000
#
# GHCR images: docker-compose.prod.yml — see README.md.
# =============================================================================

# --- Docker socket (Linux: group id of /var/run/docker.sock) ---
# macOS Docker Desktop often works with 0; Linux: $(stat -c '%g' /var/run/docker.sock)
DOCKER_GID=0

# --- Host ports (published to your machine) ---
API_PORT=8080
FE_PORT=3000
PG_PORT=5432
RMQ_PORT=5672
RMQ_MGMT_PORT=15672

# --- PostgreSQL 17 ---
PG_USER=postgres
PG_PASSWORD=change-me-postgres
PG_DB=code_training_lab

# --- RabbitMQ ---
RMQ_USER=guest
RMQ_PASSWORD=change-me-rabbitmq

# --- Host bootRun only (./gradlew :be:bootRun + Docker postgres/rabbitmq on localhost) ---
# SPRING_PROFILES_ACTIVE=local
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/code_training_lab
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=change-me-postgres
# SPRING_RABBITMQ_HOST=localhost
# SPRING_RABBITMQ_PASSWORD=change-me-rabbitmq

# --- API security & features (injected into the api container) ---
SPRING_PROFILES_ACTIVE=production
JWT_SECRET=change-me-use-at-least-32-random-characters
REGISTRATION_ENABLED=true
ACCESS_REQUESTS_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
CTL_DOCKER_ENABLED=true

# --- Runner images (docker-compose.runners.yml — `make runners`) ---
# Shared Maven cache + runner pool (host bootRun + Docker):
RUNNER_MAVEN_CACHE_VOLUME=code-challenge-ide-pro-runner-m2-cache
RUNNER_POOL_ENABLED=true
RUNNER_POOL_IDLE_MINUTES=60
# Full stack: pre-start pool containers + smoke run per language after API boot (Admin → Ops also available)
RUNNER_POOL_WARM_ON_STARTUP=true
# Docker API: persisted warm stamps (compose sets /data/code-challenge-ide-pro-ops). bootRun: leave empty to use repo root.
# CTL_OPS_DATA_DIR=
CTL_API_IMAGE=code-challenge-ide-pro-be:local
CTL_FE_IMAGE=code-challenge-ide-pro-fe:local
RUNNER_JAVA_25_IMAGE=code-challenge-ide-pro-runner-java-25:local
RUNNER_JAVA_26_IMAGE=code-challenge-ide-pro-runner-java-26:local
RUNNER_PYTHON_312_IMAGE=code-challenge-ide-pro-runner-python-312:local
RUNNER_GO_123_IMAGE=code-challenge-ide-pro-runner-go-123:local
RUNNER_NODE_22_IMAGE=code-challenge-ide-pro-runner-node-22:local
RUNNER_DOTNET_8_IMAGE=code-challenge-ide-pro-runner-dotnet-8:local
RUNNER_TYPESCRIPT_57_IMAGE=code-challenge-ide-pro-runner-typescript-57:local
RUNNER_RUST_184_IMAGE=code-challenge-ide-pro-runner-rust-184:local
RUNNER_CPP_20_IMAGE=code-challenge-ide-pro-runner-cpp-20:local
RUNNER_REACT_19_IMAGE=code-challenge-ide-pro-runner-react-19:local
RUNNER_VUE_35_IMAGE=code-challenge-ide-pro-runner-vue-35:local
RUNNER_ANGULAR_19_IMAGE=code-challenge-ide-pro-runner-angular-19:local
RUNNER_POSTGRES_17_IMAGE=code-challenge-ide-pro-runner-postgres-17:local
LSP_JAVA_IMAGE=code-challenge-ide-pro-lsp-java:local
LSP_PYTHON_IMAGE=code-challenge-ide-pro-lsp-python:local
LSP_GO_IMAGE=code-challenge-ide-pro-lsp-go:local
LSP_TYPESCRIPT_IMAGE=code-challenge-ide-pro-lsp-typescript:local
LSP_DOTNET_IMAGE=code-challenge-ide-pro-lsp-dotnet:local
LSP_RUST_IMAGE=code-challenge-ide-pro-lsp-rust:local
LSP_CPP_IMAGE=code-challenge-ide-pro-lsp-cpp:local
CTL_LSP_ENABLED=true

# --- GHCR (docker-compose.prod.yml / docker-compose.coolify.yml) ---
# CTL_IMAGE_REGISTRY=ghcr.io
# CTL_IMAGE_OWNER=your-github-username
# CTL_IMAGE_TAG=latest
#
# Coolify: set the variables above in the Coolify UI and use docker-compose.coolify.yml.
# No extra deploy command is required; see docs/coolify.md.
#
# Example GHCR runner tags (after pull-runner-images.sh):
# RUNNER_JAVA_26_IMAGE=ghcr.io/your-github-username/code-challenge-ide-pro-runner-java-26:latest
# RUNNER_POSTGRES_17_IMAGE=code-challenge-ide-pro-runner-postgres-17:local

# --- AI coaching (optional — operator pays provider usage) ---
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder

# --- Mail (welcome emails + access request notifications) ---
CTL_MAIL_ENABLED=false
CTL_MAIL_HOST=mail.privateemail.com
CTL_MAIL_PORT=587
CTL_MAIL_USERNAME=
CTL_MAIL_PASSWORD=
CTL_MAIL_LOGIN_URL=http://localhost:5173/login
CTL_MAIL_ACCESS_REQUEST_TO=you@example.com
