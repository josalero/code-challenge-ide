# =============================================================================
# Code Training Lab — docker-compose.coolify.yml
# =============================================================================
#
#   cp .env.coolify.example .env
#   # Edit secrets and CTL_IMAGE_OWNER, then:
#   docker compose -f docker-compose.coolify.yml pull
#   ./scripts/coolify-post-deploy.sh
#   docker compose -f docker-compose.coolify.yml up -d
#
# Coolify: paste these keys into the resource Environment Variables (or upload .env).
# Post-deploy: ./scripts/coolify-post-deploy.sh
# =============================================================================

# --- GHCR (required) ---
CTL_IMAGE_REGISTRY=ghcr.io
CTL_IMAGE_OWNER=your-github-username
CTL_IMAGE_TAG=latest

# --- Docker socket (required for Run tests / warm / LSP) ---
# On the Coolify VPS (SSH): stat -c '%g' /var/run/docker.sock
# Do not use 0 on Linux unless that matches the socket group.
DOCKER_GID=998

# --- Public URL (required — match Coolify HTTPS domain, no trailing slash) ---
CORS_ALLOWED_ORIGINS=https://lab.example.com

# --- Host port for code-lab-fe (Coolify proxy may ignore this) ---
FE_PORT=3001

# --- PostgreSQL (code-lab-postgres) ---
PG_USER=postgres
PG_PASSWORD=change-me-postgres
PG_DB=code_training_lab

# --- RabbitMQ (code-lab-rabbitmq) ---
RMQ_USER=guest
RMQ_PASSWORD=change-me-rabbitmq

# --- API (code-lab-api) ---
SPRING_PROFILES_ACTIVE=production
JWT_SECRET=change-me-use-at-least-32-random-characters
REGISTRATION_ENABLED=false
RUNNER_POOL_WARM_ON_STARTUP=true
RUNNER_MAVEN_CACHE_VOLUME=ctl-runner-m2-cache
CTL_LSP_ENABLED=true

# --- Runner / LSP images (set after ./scripts/coolify-post-deploy.sh) ---
# GHCR tags — replace YOUR_OWNER with CTL_IMAGE_OWNER (lowercase):
RUNNER_JAVA_26_IMAGE=ghcr.io/your-github-username/code-challenge-ide-runner-java-26:latest
RUNNER_JAVA_25_IMAGE=ghcr.io/your-github-username/code-challenge-ide-runner-java-25:latest
RUNNER_PYTHON_312_IMAGE=ghcr.io/your-github-username/code-challenge-ide-runner-python-312:latest
RUNNER_GO_123_IMAGE=ghcr.io/your-github-username/code-challenge-ide-runner-go-123:latest
RUNNER_NODE_22_IMAGE=ghcr.io/your-github-username/code-challenge-ide-runner-node-22:latest
RUNNER_DOTNET_8_IMAGE=ghcr.io/your-github-username/code-challenge-ide-runner-dotnet-8:latest
RUNNER_TYPESCRIPT_57_IMAGE=ghcr.io/your-github-username/code-challenge-ide-runner-typescript-57:latest
RUNNER_RUST_184_IMAGE=ghcr.io/your-github-username/code-challenge-ide-runner-rust-184:latest
RUNNER_CPP_20_IMAGE=ghcr.io/your-github-username/code-challenge-ide-runner-cpp-20:latest
RUNNER_REACT_19_IMAGE=ghcr.io/your-github-username/code-challenge-ide-runner-react-19:latest
RUNNER_VUE_35_IMAGE=ghcr.io/your-github-username/code-challenge-ide-runner-vue-35:latest
RUNNER_ANGULAR_19_IMAGE=ghcr.io/your-github-username/code-challenge-ide-runner-angular-19:latest
RUNNER_POSTGRES_17_IMAGE=code-challenge-ide-runner-postgres-17:local
LSP_JAVA_IMAGE=ghcr.io/your-github-username/code-challenge-ide-lsp-java:latest
LSP_PYTHON_IMAGE=code-challenge-ide-lsp-python:local
LSP_GO_IMAGE=code-challenge-ide-lsp-go:local
LSP_TYPESCRIPT_IMAGE=code-challenge-ide-lsp-typescript:local
LSP_DOTNET_IMAGE=code-challenge-ide-lsp-dotnet:local
LSP_RUST_IMAGE=code-challenge-ide-lsp-rust:local
LSP_CPP_IMAGE=code-challenge-ide-lsp-cpp:local

# --- AI coach (optional) ---
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder
