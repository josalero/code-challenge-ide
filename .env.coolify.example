# =============================================================================
# Code Training Lab — docker-compose.coolify.yml (local build on VPS)
# =============================================================================
#
#   cp .env.coolify.example .env
#   # Edit secrets + CORS + DOCKER_GID, then deploy in Coolify
#
# Coolify:
#   Base directory: repository root
#   Compose file: docker-compose.coolify.yml
#   Build: enabled (builds app, runner, LSP, and Maven cache images)
#   Extra deploy command: not required
# =============================================================================

# --- Docker socket (required for Run tests / warm / LSP) ---
# SSH: stat -c '%g' /var/run/docker.sock
DOCKER_GID=998

# --- Public URL (match Coolify HTTPS domain, no trailing slash) ---
CORS_ALLOWED_ORIGINS=https://lab.example.com

# --- PostgreSQL ---
PG_USER=postgres
PG_PASSWORD=change-me-postgres
PG_DB=code_training_lab

# --- RabbitMQ ---
RMQ_USER=guest
RMQ_PASSWORD=change-me-rabbitmq

# --- API ---
SPRING_PROFILES_ACTIVE=production
JWT_SECRET=change-me-use-at-least-32-random-characters
REGISTRATION_ENABLED=false
RUNNER_POOL_WARM_ON_STARTUP=false
RUNNER_POOL_ENABLED=true
RUNNER_MAVEN_CACHE_VOLUME=ctl-runner-m2-cache
CTL_LSP_ENABLED=true

# --- Local image tags (built on VPS; defaults match backend image inventory) ---
CTL_API_IMAGE=code-challenge-ide-be:local
CTL_FE_IMAGE=code-challenge-ide-fe:local
RUNNER_JAVA_26_IMAGE=code-challenge-ide-runner-java-26:local
RUNNER_JAVA_25_IMAGE=code-challenge-ide-runner-java-25:local
RUNNER_PYTHON_312_IMAGE=code-challenge-ide-runner-python-312:local
RUNNER_GO_123_IMAGE=code-challenge-ide-runner-go-123:local
RUNNER_NODE_22_IMAGE=code-challenge-ide-runner-node-22:local
RUNNER_DOTNET_8_IMAGE=code-challenge-ide-runner-dotnet-8:local
RUNNER_TYPESCRIPT_57_IMAGE=code-challenge-ide-runner-typescript-57:local
RUNNER_RUST_184_IMAGE=code-challenge-ide-runner-rust-184:local
RUNNER_CPP_20_IMAGE=code-challenge-ide-runner-cpp-20:local
RUNNER_REACT_19_IMAGE=code-challenge-ide-runner-react-19:local
RUNNER_VUE_35_IMAGE=code-challenge-ide-runner-vue-35:local
RUNNER_ANGULAR_19_IMAGE=code-challenge-ide-runner-angular-19:local
RUNNER_POSTGRES_17_IMAGE=code-challenge-ide-runner-postgres-17:local
LSP_JAVA_IMAGE=code-challenge-ide-lsp-java:local
LSP_PYTHON_IMAGE=code-challenge-ide-lsp-python:local
LSP_GO_IMAGE=code-challenge-ide-lsp-go:local
LSP_TYPESCRIPT_IMAGE=code-challenge-ide-lsp-typescript:local
LSP_DOTNET_IMAGE=code-challenge-ide-lsp-dotnet:local
LSP_RUST_IMAGE=code-challenge-ide-lsp-rust:local
LSP_CPP_IMAGE=code-challenge-ide-lsp-cpp:local

# --- AI coach (optional) ---
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder
