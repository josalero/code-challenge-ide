{
	admin off
	auto_https off
	servers {
		trusted_proxies static private_ranges
	}
}

:80 {
	root * /usr/share/caddy
	encode zstd gzip
	log {
		output stdout
		format filter {
			wrap console {
				time_format wall_milli
				duration_format string
			}
			request>headers delete
			resp_headers delete
		}
	}
	@healthcheck {
		remote_ip 127.0.0.1
		path /
	}
	log_skip @healthcheck
	@staticAssets path_regexp \.(js|css|png|jpe?g|gif|ico|woff2?|svg|map)$
	log_skip @staticAssets
	header {
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval'; worker-src 'self' blob:; connect-src 'self' data: ws: wss:; manifest-src 'self'; media-src 'self' blob:"
		Permissions-Policy "accelerometer=(), autoplay=(), camera=(), display-capture=(), encrypted-media=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		-Server
	}

	@api path /api /api/*
	handle @api {
		reverse_proxy code-challenge-ide-pro-api:8080 {
			flush_interval -1
			stream_close_delay 5m
			transport http {
				dial_timeout 30s
			}
		}
	}

	handle {
		try_files {path} /index.html
		file_server
	}
}
